{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Battery SipJuice",
  "version": "0.4.2",
  "identifier": "com.batterysipjuice.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Battery SipJuice",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "copyright": "Copyright © 2026 EmberLuo",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "resources": {
      "../NOTICE": "NOTICE"
    },
    "icon": [
      "icons/16x16.png",
      "icons/24x24.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/96x96.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png"
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/battery-sipjuice.svg": "../src/app-icon.svg"
        }
      },
      "deb": {
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/battery-sipjuice.svg": "../src/app-icon.svg"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/battery-sipjuice.svg": "../src/app-icon.svg"
        }
      }
    },
    "category": "Utility",
    "shortDescription": "本机电池监控与健康管理",
    "longDescription": "Battery SipJuice — Linux 电源工具：电池健康、实时电气量、充放电监控、温度与电池养护提醒。"
  },
  "plugins": {}
}
